{
  "name": "huascaran",
  "version": "1.2.1",
  "description": "Sistema de Inventario y POS - HUASCARAN",
  "main": "electron/main.js",
  "scripts": {
    "dev:backend": "cd server && node index.js",
    "dev:frontend": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:full": "npm run rebuild:dev && concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "rebuild:dev": "cd server && npm rebuild better-sqlite3",
    "rebuild:native": "npx @electron/rebuild -f -w better-sqlite3 --module-dir server",
    "build:frontend": "cd client && npm run build",
    "start": "electron .",
    "compile:backend": "node server/compile_server.js",
    "electron:build": "npm run build:frontend && npm run rebuild:native && npm run compile:backend && npx electron-builder --win"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "electron-updater": "^6.8.9",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.6"
  },
  "build": {
    "appId": "com.huascaran.pos",
    "productName": "HUASCARAN",
    "publish": {
      "provider": "github",
      "owner": "TU_USUARIO_GITHUB",
      "repo": "huascaran-releases",
      "private": false
    },
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "client/dist",
        "to": "client/dist"
      },
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!data/inventario.db",
          "!data/backups/**",
          "!licencia.js"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Huascaran",
      "language": "3082",
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico"
    }
  }
}
